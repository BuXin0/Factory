.container {
  min-height: 100vh;
  background: #020617;
  padding: 0 0 40rpx 0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  background: #0f172a;
  border-bottom: 1px solid #1e293b;
}

.back-btn, .logout-btn {
  font-size: 28rpx;
  color: #22d3ee;
  padding: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #f8fafc;
}

.admin-info {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
  background: #0f172a;
  margin-bottom: 24rpx;
  border-bottom: 1px solid #1e293b;
}

.admin-badge {
  background: linear-gradient(135deg, #22d3ee 0%, #0ea5e9 100%);
  color: #020617;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.admin-name {
  font-size: 32rpx;
  color: #e2e8f0;
  font-weight: 500;
}

.user-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  margin-left: 16rpx;
}

.btn-export-small {
  background: linear-gradient(135deg, #22d3ee 0%, #0ea5e9 100%);
  color: #000000;
  font-size: 22rpx;
  font-weight: 600;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1;
}

.btn-export-small:active {
  transform: scale(0.95);
}

.section {
  margin: 0 32rpx 32rpx;
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-title {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid #1e293b;
  background: #1e293b;
}

.section-title.sub {
  background: transparent;
  margin-top: 24rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
}

.count {
  font-size: 26rpx;
  color: #94a3b8;
  margin-left: 12rpx;
}

.user-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.user-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1px solid #1e293b;
  background: #0f172a;
}

.user-item:last-child {
  border-bottom: none;
}

.user-item.selected {
  background: #1e3a5f;
  border-left: 4rpx solid #22d3ee;
}

.user-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 30rpx;
  color: #e2e8f0;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.phone {
  font-size: 24rpx;
  color: #94a3b8;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #1e293b;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #22d3ee 0%, #0ea5e9 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-fill.completed {
  background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%);
}

.progress-text {
  font-size: 22rpx;
  color: #94a3b8;
  min-width: 120rpx;
  text-align: right;
}

.register-time {
  font-size: 22rpx;
  color: #64748b;
  margin-left: 24rpx;
}

.empty {
  padding: 60rpx;
  text-align: center;
  color: #64748b;
  font-size: 28rpx;
}

.user-detail {
  padding: 24rpx 32rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1px solid #1e293b;
}

.detail-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #94a3b8;
}

.value {
  font-size: 28rpx;
  color: #e2e8f0;
}

.log-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.log-item {
  padding: 24rpx 32rpx;
  border-bottom: 1px solid #1e293b;
  background: #0f172a;
}

.log-item:last-child {
  border-bottom: none;
}

.log-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.log-type {
  font-size: 26rpx;
  color: #22d3ee;
  font-weight: 500;
}

.log-time {
  font-size: 22rpx;
  color: #64748b;
}

.log-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.log-content text {
  font-size: 24rpx;
  color: #94a3b8;
}
