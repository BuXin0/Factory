.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.auth-card {
  width: 100%;
  max-width: 600rpx;
  margin: 0 auto;
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: 20rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
  text-align: center;
  margin-bottom: 48rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
  display: block;
  text-align: center;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #020617;
  border: 1px solid #334155;
  border-radius: 12rpx;
  padding: 0 20rpx;
  color: #e2e8f0;
  font-size: 28rpx;
  text-align: center;
  box-sizing: border-box;
}

.input:focus {
  border-color: #22d3ee;
}

.error {
  color: #ef4444;
  font-size: 24rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  background: #22d3ee;
  color: #020617;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  margin-bottom: 32rpx;
}

.switch-mode {
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
  display: flex;
  justify-content: center;
  align-items: center;
  white-space: nowrap;
}

.link {
  color: #22d3ee;
  margin-left: 8rpx;
}

.footer {
  margin-top: 80rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  display: block;
}