.container {
  padding: 24rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
  min-height: 100vh;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f8fafc;
  letter-spacing: 1rpx;
}

.status-tag {
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-ok {
  background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(34, 197, 94, 0.4);
}

.status-warn {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.4);
}

.status-danger {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.4);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.85; }
}

.status-desc {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.6;
}

/* 导出卡片 */
.export-card {
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(30, 41, 59, 0.8) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
  backdrop-filter: blur(10rpx);
}

.export-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
  margin-bottom: 12rpx;
  text-align: center;
}

.export-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.btn-export {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #000000;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  height: 88rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.4);
  transition: transform 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-export:active {
  transform: scale(0.98);
}

/* 参数卡片 */
.param-card {
  background: linear-gradient(135deg, rgba(30, 41, 59, 0.9) 0%, rgba(15, 23, 42, 0.95) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.param-card-ok {
  border-color: rgba(34, 197, 94, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(34, 197, 94, 0.15);
}

.param-card-warn {
  border-color: rgba(245, 158, 11, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(245, 158, 11, 0.15);
}

.param-card-danger {
  border-color: rgba(239, 68, 68, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(239, 68, 68, 0.2);
}

.param-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.param-label {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 500;
}

.param-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.param-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #f8fafc;
  letter-spacing: -1rpx;
}

.param-unit {
  font-size: 28rpx;
  color: #64748b;
  margin-left: 12rpx;
  font-weight: 500;
}

.param-number.ok { color: #22c55e; }
.param-number.warn { color: #f59e0b; }
.param-number.danger { color: #ef4444; }

/* 滑块样式 */
.slider-container {
  margin: 24rpx 0;
}

slider {
  margin: 0;
}

/* 指示条 */
.gauge-container {
  margin-top: 20rpx;
}

.gauge-bg {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  position: relative;
  overflow: hidden;
}

.gauge-range {
  position: absolute;
  height: 100%;
  border-radius: 999rpx;
  transition: all 0.3s ease;
}

.gauge-range.ok {
  background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%);
}

.gauge-range.warn {
  background: linear-gradient(90deg, #f59e0b 0%, #d97706 100%);
}

.gauge-range.danger {
  background: linear-gradient(90deg, #ef4444 0%, #dc2626 100%);
}

.gauge-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.gauge-label {
  font-size: 22rpx;
  color: #64748b;
}

.gauge-label.center {
  color: #94a3b8;
  font-size: 24rpx;
}
