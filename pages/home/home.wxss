.input {
  margin-top: 16rpx;
  border: 1px solid #334155;
  border-radius: 12rpx;
  height: 72rpx;
  padding: 0 16rpx;
  color: #e2e8f0;
  background: #0b1220;
}

.admin-card {
  background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%);
  border: 1px solid #22d3ee;
  cursor: pointer;
}

.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.admin-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #22d3ee;
}

.admin-arrow {
  font-size: 36rpx;
  color: #22d3ee;
}

.admin-desc {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  display: block;
}

.logout-card {
  background: #1e293b;
  border: 1px solid #334155;
  cursor: pointer;
  text-align: center;
  padding: 32rpx;
}

.logout-content {
  display: flex;
  justify-content: center;
  align-items: center;
}

.logout-text {
  font-size: 30rpx;
  color: #ef4444;
  font-weight: 500;
}
