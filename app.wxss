page {
  background: #020617;
  color: #e2e8f0;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
}

.sub {
  color: #94a3b8;
  margin-top: 8rpx;
}

.btn {
  margin-top: 16rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  margin-right: 10rpx;
}

.ok {
  color: #22c55e;
  border: 1px solid #22c55e;
}

.warn {
  color: #facc15;
  border: 1px solid #facc15;
}

.danger {
  color: #ef4444;
  border: 1px solid #ef4444;
}

.big-number {
  font-size: 56rpx;
  font-weight: 700;
}
